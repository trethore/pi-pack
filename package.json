{
  "name": "pi-pack",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Monorepo for pi extensions.",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=22 <25"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "knip": "knip",
    "lint:dead": "knip --include files",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier . --write --log-level warn",
    "format:check": "prettier . --check",
    "importpi": "node scripts/importpi.ts",
    "dev": "pi -e .",
    "dev:pi-cut": "pi -e ./packages/pi-cut",
    "dev:pi-codexify": "pi -e ./packages/pi-codexify",
    "dev:pi-codeact": "pi -e ./packages/pi-codeact",
    "dev:pi-handy": "pi -e ./packages/pi-handy",
    "dev:pi-command-template": "pi -e ./packages/pi-command-template",
    "dev:pi-tiny-mcp": "pi -e ./packages/pi-tiny-mcp",
    "dev:pi-toolbox": "pi -e ./packages/pi-toolbox",
    "dev:pi-toolmask": "pi -e ./packages/pi-toolmask",
    "install:global": "pi install .",
    "install:local": "pi install -l .",
    "install:global:pi-cut": "pi install ./packages/pi-cut",
    "install:local:pi-cut": "pi install -l ./packages/pi-cut",
    "install:global:pi-codexify": "pi install ./packages/pi-codexify",
    "install:local:pi-codexify": "pi install -l ./packages/pi-codexify",
    "install:global:pi-codeact": "pi install ./packages/pi-codeact",
    "install:local:pi-codeact": "pi install -l ./packages/pi-codeact",
    "install:global:pi-handy": "pi install ./packages/pi-handy",
    "install:local:pi-handy": "pi install -l ./packages/pi-handy",
    "install:global:pi-command-template": "pi install ./packages/pi-command-template",
    "install:local:pi-command-template": "pi install -l ./packages/pi-command-template",
    "install:global:pi-tiny-mcp": "pi install ./packages/pi-tiny-mcp",
    "install:local:pi-tiny-mcp": "pi install -l ./packages/pi-tiny-mcp",
    "install:global:pi-toolbox": "pi install ./packages/pi-toolbox",
    "install:local:pi-toolbox": "pi install -l ./packages/pi-toolbox",
    "install:global:pi-toolmask": "pi install ./packages/pi-toolmask",
    "install:local:pi-toolmask": "pi install -l ./packages/pi-toolmask",
    "jscpd": "jscpd packages scripts --format typescript --no-tips"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.0 <1"
  },
  "imports": {
    "#pi-cut/*": "./packages/pi-cut/src/*",
    "#pi-codexify/*": "./packages/pi-codexify/src/*",
    "#pi-codeact/*": "./packages/pi-codeact/src/*",
    "#pi-handy/*": "./packages/pi-handy/src/*",
    "#pi-command-template/*": "./packages/pi-command-template/src/*",
    "#pi-tiny-mcp/*": "./packages/pi-tiny-mcp/src/*",
    "#pi-toolbox/*": "./packages/pi-toolbox/src/*",
    "#pi-toolmask/*": "./packages/pi-toolmask/src/*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@eslint/js": "9.39.4",
    "@types/node": "^22.19.19",
    "eslint": "9.39.4",
    "eslint-plugin-unicorn": "64.0.0",
    "jscpd": "^5.0.9",
    "knip": "^6.11.0",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "4.1.5"
  },
  "pi": {
    "extensions": [
      "packages/*/src/index.ts"
    ]
  },
  "allowScripts": {
    "@google/genai@1.52.0": true,
    "protobufjs@7.5.9": true,
    "protobufjs@7.5.8": true
  }
}

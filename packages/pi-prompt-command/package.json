{
  "name": "@trethore/pi-prompt-command",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Inject command output in your prompt files via command placeholders.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "prompt"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.78.0 <1"
  },
  "imports": {
    "#src/*": "./src/*",
    "#pi-prompt-command/*": "./src/*"
  },
  "dependencies": {
    "@trethore/pi-shared": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}

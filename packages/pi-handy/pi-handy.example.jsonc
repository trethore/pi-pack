{
  // Master switch for pi-handy.
  "enabled": true,

  // /thinkinglevel <level>
  "thinkingLevel": {
    "enabled": true
  },

  // /showsysprompt [prompt|tools]
  "showSysprompt": {
    "enabled": true
  },

  // /dumpcontext
  "dumpContext": {
    "enabled": true
  },

  // Notify how long the agent took when it finishes.
  "timeTaken": {
    "enabled": true
  }
}

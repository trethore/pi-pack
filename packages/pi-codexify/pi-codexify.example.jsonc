{
  "enabled": true,

  "controls": {
    "enabled": true,

    // Controls OpenAI Responses / Codex-style payload text verbosity.
    // Supported values: "low", "medium", "high".
    // Omit this key, or set it to null, to avoid overriding the provider payload.
    // In project config, null also disables an inherited global override.
    "verbosity": "medium",

    // Controls reasoning.summary for reasoning-capable OpenAI Responses / Codex models.
    // Supported values: "auto", "concise", "detailed", "none".
    // "none" actively removes reasoning.summary from outgoing supported payloads.
    // Omit this key, or set it to null, to avoid overriding the provider payload.
    // In project config, null also disables an inherited global override.
    "reasoningSummary": "auto",

    // Enables the native OpenAI Codex web_search tool.
    "webSearch": true,

    // Controls Responses API service tier for supported Codex payloads.
    // Supported values: "default", "priority".
    // "priority" requests priority processing.
    // "default" leaves the provider payload unchanged and uses the provider default.
    "serviceTier": "default"
  },

  // Enables /codexify usage.
  "usage": true,

  // Enables /codexify reset use|details.
  // /codexify reset use always asks for confirmation before consuming a credit.
  "reset": true
}

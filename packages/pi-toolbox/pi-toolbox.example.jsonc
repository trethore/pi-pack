{
  // Master switch for pi-toolbox.
  "enabled": true,

  // glob tool powered by rg --files -g.
  "glob": {
    "enabled": true,
    "defaultLimit": 100
  },

  // grep tool powered by rg -n.
  "grep": {
    "enabled": true,
    "defaultLimit": 200,
    // Omit defaultLimitPerFile for no per-file default limit.
    // "defaultLimitPerFile": 30,
    "defaultMaxCharsPerMatch": 200
  }
}

{
  "name": "@trethore/pi-codeact",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "CodeAct-style TypeScript execution tool for Pi.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "codeact",
    "tools"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.2 <1"
  },
  "dependencies": {
    "@trethore/pi-shared": "*",
    "typebox": "^1.1.34"
  },
  "imports": {
    "#src/*": "./src/*",
    "#pi-codeact/*": "./src/*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
